SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Set to 'True' to use PostgreSQL, 'False' to use SQLite
USE_POSTGRES=False

# SQLite Configuration (used when USE_POSTGRES=False)
SQLITE_NAME=db.sqlite3

# PostgreSQL Configuration (used when USE_POSTGRES=True)
POSTGRES_DB=eda_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SSO Configuration
SSO_BASE_URL=https://sso.arnatech.id
SSO_PUBLIC_KEY_PATH=public.pem

# Shared public JWT cookies across subdomains (e.g. account.* and employee.*). Prod: .arnatech.id
# Leave empty locally: public SSO cookies are not set (no Domain=).
PUBLIC_AUTH_COOKIE_DOMAIN=
# Optional: SameSite for public cookies (Lax | Strict | None). None requires Secure.
# SSO_PUBLIC_COOKIE_SAMESITE=Lax
# Default False: arna_sso_* readable by JS (SPAs on sibling subdomains). True = HttpOnly (more XSS-safe, no document.cookie).
# SSO_PUBLIC_COOKIE_HTTPONLY=False
# Use secure session cookies on HTTPS
# SESSION_COOKIE_SECURE=True
# Optional: Django session cookie domain for cross-subdomain sessions
# SESSION_COOKIE_DOMAIN=.arnatech.id

# JWT Configuration
JWT_ALGORITHM=RS256
JWT_AUDIENCE=employee-daily-activity
JWT_ISSUER=sso.arnatech.id

# Note: You need to create the public.pem file with the RSA public key
# from your SSO administrator. This file is required for JWT token verification.
# 
# To use PostgreSQL:
# 1. Set USE_POSTGRES=True
# 2. Update POSTGRES_PASSWORD with your actual PostgreSQL password
# 3. Install psycopg2 package: pip install psycopg2-binary
# 4. Create the database: createdb eda_db
# 5. Run migrations: python manage.py migrate 